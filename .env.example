# =============================================================================
# Computer Agent — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- LLM Providers ---
# Set the key for the provider you want to use.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# --- LLM Provider Selection ---
# LLM_PROVIDER: "auto" (detect from model name) | "anthropic" | "openai" | "google" | "litellm"
LLM_PROVIDER=auto

# --- Model Selection ---
# Anthropic:  claude-sonnet-4-20250514  |  claude-haiku-4-20250514
# OpenAI:     gpt-4o  |  o3-mini
# Gemini:     gemini-2.5-flash  |  gemini-2.5-pro
# Ollama:     ollama/llama3  |  ollama/mistral  (requires local Ollama install)
# LiteLLM:    bedrock/anthropic.claude-3-sonnet  |  azure/my-gpt4  |  openrouter/...
PRIMARY_MODEL=claude-sonnet-4-20250514
PLANNER_MODEL=claude-sonnet-4-20250514
VISION_MODEL=claude-sonnet-4-20250514
# Cheaper model for routing/classification
ROUTER_MODEL=claude-haiku-4-20250514

# --- Local / Proxy endpoint override (optional) ---
# Override the API base URL — useful for LM Studio, Ollama, Azure, or a proxy
# LLM_API_BASE=http://localhost:1234/v1
OLLAMA_BASE_URL=http://localhost:11434

# --- Database (PostgreSQL + pgvector) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=agent
POSTGRES_PASSWORD=agentpass
POSTGRES_DB=computer_agent
DATABASE_URL=postgresql://agent:agentpass@localhost:5432/computer_agent

# --- Memory ---
# Similarity threshold for trace replay (0.0 - 1.0)
MEMORY_SIMILARITY_THRESHOLD=0.85
# Max traces to retrieve for context
MEMORY_TOP_K=5

# --- Security: Allowed Paths (colon-separated) ---
# Agent can only read/write files within these paths
ALLOWED_READ_PATHS=~/Documents:~/Downloads:~/Desktop
ALLOWED_WRITE_PATHS=~/Documents:~/Downloads:~/Desktop

# --- Security: Allowed Shell Commands (comma-separated) ---
# Leave blank to use the built-in safe defaults
ALLOWED_SHELL_COMMANDS=

# --- Security: Allowed API Domains (comma-separated) ---
# Leave blank to use the built-in safe defaults
ALLOWED_API_DOMAINS=

# --- Browser ---
BROWSER_TYPE=chromium
# Set to 1 to run browser headlessly
BROWSER_HEADLESS=0
# Persistent browser profile directory
BROWSER_USER_DATA_DIR=~/.computer_agent/browser_profile

# --- HITL ---
# How long to wait for human approval before auto-cancelling (seconds)
HITL_APPROVAL_TIMEOUT=300
# "pause": wait indefinitely for the user's decision (recommended with the daemon)
# "expire": auto-deny after HITL_APPROVAL_TIMEOUT seconds
HITL_TIMEOUT_ACTION=pause

# --- Autonomy ---
# low: ask before anything with side effects
# medium: handle simple reversible actions, ask for major ones
# high: handle most things, ask only for critical actions
# (Runtime changes via `computer-agent mode <level>` are persisted and win over this.)
AUTONOMY_LEVEL=medium

# --- Daemon ---
DAEMON_HOST=127.0.0.1
DAEMON_PORT=8765

# --- Task manager / scheduler ---
# How many tasks may run at once (keep 1: mouse/keyboard can't be shared)
MAX_CONCURRENT_TASKS=1
SCHEDULER_ENABLED=true

# --- Observability ---
OTEL_ENABLED=true
OTEL_EXPORTER=console
# Optional: OTLP endpoint for Grafana/Jaeger
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- Agent Behavior ---
MAX_RETRIES=3
STEP_TIMEOUT_SECONDS=120
MAX_CONVERSATION_TURNS=50
